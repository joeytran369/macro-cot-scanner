# OANDA API (required for live prices + sentiment)
# Get yours at: https://www.oanda.com/demo-account/
OANDA_TOKEN=your_oanda_api_token_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENV=practice

# FRED API (required for macro data: DXY, US10Y, VIX, etc.)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Server
HOST=0.0.0.0
PORT=8888
